# ============================================================================
# AlphaAgent Demo — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the required values.
#   cp .env.template .env
# ============================================================================

# --- Required ---

# NVIDIA NGC API Key (obtain from https://org.ngc.nvidia.com/)
# Required for pulling NIM container images and model weights.
NGC_API_KEY=

# --- Azure Deployment (Optional, defaults shown) ---

# Resource group name (must exist or will be created by deploy.sh)
# RG_NAME=DNvidiaANF

# Azure region (must have NVIDIA GPU VM quota)
# LOCATION=eastus2

# Resource name prefix
# PREFIX=alpha-ai

# AKS GPU node pool VM size (must have NVIDIA GPU)
# Standard_NC6s_v3   = 1x V100 16GB  (~$0.90/hr)  — good for demo
# Standard_NC24ads_A100_v4 = 1x A100 80GB (~$3.67/hr) — production grade
# GPU_VM_SIZE=Standard_NC6s_v3

# --- AKS Autoscaler (GPU pool scales to 0 when idle, saves 50-70% cost) ---
# GPU_NODE_COUNT=2         # Initial GPU node count
# GPU_NODE_MIN_COUNT=0     # Min nodes (0 = scale to zero when no NIM pods scheduled)
# GPU_NODE_MAX_COUNT=4     # Max burst capacity

# --- Azure NetApp Files ---
# ANF_SERVICE_LEVEL=Standard    # Standard | Premium | Ultra
# ANF_POOL_SIZE_TIB=4           # Minimum 4 TiB

# --- ANF Object REST API (Optional — S3-compatible access for zero-ETL demo) ---
# These are configured post-deployment when the Object REST API feature is enabled.
# ANF_OBJECT_REST_ENDPOINT=https://<anf-ip-or-fqdn>
# ANF_ACCESS_KEY=
# ANF_SECRET_KEY=
# ANF_BUCKET_NAME=fsi-dropzone

# --- Reranker Integration ---
# Enables NV-RerankQA-Mistral-4B-v3 cross-encoder in the RAG pipeline.
# Set to "false" if the reranker NIM pod is not deployed (saves 1 GPU).
# RERANK_ENABLED=true
# RERANK_OVERFETCH_FACTOR=3    # Fetch 3x candidates from Milvus, rescore to top_k

# --- Azure AD / Entra ID Authentication ---
# Set AUTH_ENABLED=true to require Azure AD login on the Streamlit UI.
# Register an app in Entra ID → App registrations → New registration.
# AUTH_ENABLED=false
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# AZURE_AD_REDIRECT_URI=http://localhost:8501

# --- Monitoring ---
# Grafana admin password (change in production; store in Key Vault)
# GRAFANA_ADMIN_PASSWORD=AlphaAgent-Demo-2024
